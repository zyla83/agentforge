{
  "name": "agentforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "check": "biome check .",
    "example:basic": "pnpm --filter @agentforge/example-basic run start",
    "example:chat": "pnpm --filter @agentforge/example-chat-cli start",
    "example:ollama": "pnpm --filter @agentforge/example-ollama start",
    "example:tools": "pnpm --filter @agentforge/example-tool-execution start",
    "format": "biome format --write .",
    "test": "pnpm run build && vitest run",
    "test:storage-filesystem": "vitest run tests/storage-filesystem"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
